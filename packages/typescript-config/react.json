{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": ["./base.json", "./strict-flags.json"],
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "types": ["node"]
  }
}
