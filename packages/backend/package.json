{
  "name": "backend",
  "version": "1.0.0",
  "description": "rest api for junglify's database",
  "homepage": "https://github.com/alexschmidt76/junglify#readme",
  "bugs": {
    "url": "https://github.com/alexschmidt76/junglify/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexschmidt76/junglify.git"
  },
  "license": "ISC",
  "author": {
    "name": "Alex Schmidt"
  },
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsc && node --env-file=.env ./dist/server.js",
    "start": "node ./dist/server.js",
    "test": "\"echo \\\"No tests yet\\\" && exit 0\"",
    "build": "tsc",
    "lint": "eslint src/",
    "check-types": "tsc --noEmit",
    "prepublish": "npm run build",
    "migrate": "node --env-file=.env ./db/migrate.js"
  },
  "files": [
    "./bin/*",
    "./dist/*"
  ],
  "typings": "./dist/server.d.ts",
  "dependencies": {
    "@auth/express": "^0.12.2",
    "@auth/pg-adapter": "^1.11.2",
    "express": "^5.2.1",
    "fs": "^0.0.1-security",
    "path": "^0.12.7",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "cors": "^2.8.6",
    "eslint": "^9.39.1"
  }
}
