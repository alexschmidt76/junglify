{
  "name": "junglify",
  "version": "0.4.2",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test"
  },
  "dependencies": {
    "better-auth": "^1.6.15"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.2",
    "@vercel/node": "^5.1.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "allowScripts": {
    "esbuild@0.27.0": true
  }
}
