{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["DB_URL", "PORT", "EXTENSION_ID", "BETTER_AUTH_SECRET"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["DB_URL", "PORT", "EXTENSION_ID", "BETTER_AUTH_SECRET"]
    }
  }
}
