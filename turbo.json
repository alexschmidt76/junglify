{
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "PORT", "EXTENSION_ID", "BETTER_AUTH_SECRET", "DB_PUBLIC_URL", "DB_URL",
        "PGDATABASE", "PGHOST", "PGPASSWORD", "PGUSER"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "PORT", "EXTENSION_ID", "BETTER_AUTH_SECRET", "DB_PUBLIC_URL", "DB_URL",
        "PGDATABASE", "PGHOST", "PGPASSWORD", "PGUSER"
      ]
    },
    "migrate": {
      "cache": false,
      "passThroughEnv": ["DB_PUBLIC_URL"]
    }
  }
}
