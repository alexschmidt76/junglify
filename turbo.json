{
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "JUNGLIFY_WEBSITE_URL", "BETTER_AUTH_SECRET", "DEV_DATABASE_URL", "DATABASE_URL", "NODE_ENV"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": [
        "JUNGLIFY_WEBSITE_URL", "BETTER_AUTH_SECRET", "DEV_DATABASE_URL", "DATABASE_URL", "NODE_ENV"
      ]
    },
    "migrate": {
      "cache": false,
      "passThroughEnv": ["DEV_DATABASE_URL"]
    }
  }
}
