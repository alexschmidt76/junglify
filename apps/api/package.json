    "test:watch": "vitest",
    "migrate": "node --env-file=.env ./db_migration/migrate.js"
  },
  "dependencies": {
    "@vercel/node": "^5.8.12",
    "kysely": "^0.29.2",
    "kysely-postgres-js": "^3.0.0",
    "postgres": "^3.4.9",
    "vercel": "^54.9.1",
    "@repo/utils": "*"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "eslint": "^9.39.1",
    "vitest": "^4.1.8"
  }
}
