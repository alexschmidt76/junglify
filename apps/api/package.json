  },
  "license": "ISC",
  "author": {
    "name": "Alex Schmidt"
  },
  "type": "module",
  "scripts": {
    "dev": "npm run dev:vercel",
    "dev:vercel": "vercel dev --listen 3002",
    "check-types": "tsc --noEmit",
